# ============================================
# Messenger-Claude Bot — Environment Variables
# Arise Media & IT Consultants
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Facebook / Meta ---
FACEBOOK_PAGE_ACCESS_TOKEN=your_facebook_page_access_token_here
FACEBOOK_VERIFY_TOKEN=your_custom_verify_token_here
# FACEBOOK_APP_SECRET=your_facebook_app_secret_here  # Optional: for payload verification

# --- Claude Behaviour ---
# Customize this prompt to define how Claude responds to your users
CLAUDE_SYSTEM_PROMPT=You are a helpful assistant for Arise Media & IT Consultants. You are friendly, professional, and concise. Always respond in the same language the user writes in.

# --- Server ---
PORT=3000
